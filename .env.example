# URL pública del sitio (OG, enlaces de referido, imágenes Payload)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Solo desarrollo: hosts adicionales permitidos (Next.js 16 bloquea cross-origin en dev).
# Si abres el sitio por IP de red (ej. http://192.168.1.10:3000), lista la IP o el hostname:
# NEXT_DEV_ALLOWED_ORIGINS=192.168.1.10,10.0.0.6

# WhatsApp mostrado en el sitio (E.164 sin +) — también editable en Payload > SiteConfig
NEXT_PUBLIC_WHATSAPP=18095551234

# Payload CMS
PAYLOAD_SECRET=genera_un_string_largo_aleatorio
# Local (SQLite)
# DATABASE_URL=file:./payload.db
# Producción: pooler (6543) o session (5432) — la app añade sslmode=require y uselibpqcompat=true,
# y pgbouncer=true solo en puerto 6543.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# Payload en producción: define solo estas (en Vercel quita variables POSTGRES_* si las añadió el integrador de Supabase).
# DATABASE_URL = Transaction pooler (6543).
# DATABASE_DIRECT_URL = Session pooler (IPv4) o db.*:5432 si tienes add-on IPv6; misma contraseña que DATABASE_URL.
# Alternativas al mismo efecto: DATABASE_URL_UNPOOLED o DIRECT_URL.
# Ejemplo session pooler (host/puerto los copias del panel Supabase):
# DATABASE_DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# Vercel Blob: debe coincidir con vercel_blob_rw_<store>_<secret>; si no, el plugin se omite (no rompe Payload).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx
#
# Comprobar Payload + Postgres: GET /api/health-payload → ok / hint / errorType.
# Opcional (solo depuración): PAYLOAD_PUBLIC_HEALTH_DETAILS=true → messagePreview sin contraseñas en JSON.
#
# Migraciones: el prebuild NO ejecuta `payload migrate` salvo PAYLOAD_PREBUILD_MIGRATE=true (ver scripts/prebuild-payload-migrate.mjs).
# Siempre se aplican pendientes al arrancar Payload (`prodMigrations`). Nueva migración:
#   DATABASE_URL=postgresql://… npm run migrate:create -- nombre

# Auth.js / NextAuth v5
AUTH_SECRET=genera_otro_string_largo_aleatorio
# Opcional en dev; en producción debe coincidir con el dominio
AUTH_URL=http://localhost:3000
